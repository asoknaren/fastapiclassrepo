FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

RUN pip install --no-cache-dir uv

COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-dev

COPY bug_employee_api.py \
     bug_api.py \
     employee_api.py \
     bug_employee_store.py \
     .env ./

EXPOSE 8001

CMD ["uv", "run", "uvicorn", "bug_employee_api:app", "--host", "0.0.0.0", "--port", "8001"]
